{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    },
    {
      "label": "npm: check-types",
      "type": "npm",
      "script": "check-types",
      "problemMatcher": "$tsc",
      "group": "build"
    }
  ]
}
